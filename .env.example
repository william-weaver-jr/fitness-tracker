# FitTrack environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── Runtime ──────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ─── HTTP server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Oracle Database ──────────────────────────────────────────────────────
# Local dev: oracle:1521 inside docker-compose, or localhost:1521 from host.
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=FREEPDB1
ORACLE_USER=fittrack_app
ORACLE_PASSWORD=fittrack_dev_password_change_me
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1

# ─── Redis (CP4+; placeholder in CP1) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Security ─────────────────────────────────────────────────────────────
# Used in CP2; generate with: openssl genpkey -algorithm RSA -pkcs8 -out key.pem
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000

# ─── CORS ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# ─── Dev test page ────────────────────────────────────────────────────────
# Set to "true" to expose /dev test page. Force-disabled when ENV=production.
ENABLE_DEV_TEST_PAGE=true
